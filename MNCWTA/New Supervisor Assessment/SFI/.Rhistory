SFI_7 <- SFI_6 |>
mutate(kadushin = case_when(
group_id >= 1 & group_id <= 20 ~ "Administrative",
group_id >= 21 & group_id <= 36 ~ "Educational",
.default = "Supportive")
) |>
select(-group_id)
#| label: SFI-export-final
#| message: FALSE
#| warning: FALSE
#| echo: TRUE
write.csv(SFI_7, "SFI_clean.csv")
